# ── 필수 환경변수 ──────────────────────────────────────────────
# Vercel 배포 시: Settings > Environment Variables에 추가
# 로컬 실행 시: 이 파일을 .env로 복사 후 값 입력

# OpenAI - 임베딩 생성용
OPENAI_API_KEY=sk-proj-your_openai_api_key_here

# Pinecone - 벡터 DB
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=nodongok-bestqna

# Anthropic Claude - 챗봇 응답 생성용
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here

# ── 선택 환경변수 ──────────────────────────────────────────────

# Google Gemini - Claude/OpenAI 폴백용 (선택)
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase - Q&A 저장용
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# 법제처 국가법령정보 Open API - 실시간 법조문 조회용 (선택)
LAW_API_KEY=your_law_api_key_here

# 관리자 페이지 - /admin 접속용 비밀번호
ADMIN_PASSWORD=your_admin_password_here
# ADMIN_JWT_SECRET=별도_JWT_시크릿 (미설정 시 ADMIN_PASSWORD 사용)

# ── 검증 ──────────────────────────────────────────────────────
# python3 check_env.py  — 배포 전 환경변수 검증
