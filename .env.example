# ── 필수 환경변수 ──────────────────────────────────────────────
# Vercel 배포 시: Settings > Environment Variables에 추가
# 로컬 실행 시: 이 파일을 .env로 복사 후 값 입력

# OpenAI - 임베딩 생성용
OPENAI_API_KEY=sk-proj-your_openai_api_key_here

# Pinecone - 벡터 DB
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=semiconductor-lithography

# Anthropic Claude - 챗봇 응답 생성용
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here

# ── 선택 환경변수 ──────────────────────────────────────────────

# Google Gemini - Claude/OpenAI 폴백용 (선택)
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase - Q&A 저장용
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# 법제처 국가법령정보 Open API - 실시간 법조문·판례 조회용 (선택)
ODCLOUD_API_KEY=a0b5fdbe24bf7f5d77b5c3a807e64aa961735cc7831e6b093614c2c1a440f6af
LAW_API_KEY=kcsvictory
# LAW_API_SEARCH_TIMEOUT=3       # 검색 API 타임아웃(초), 기본 3초
# LAW_API_SERVICE_TIMEOUT=8      # 조문 조회 API 타임아웃(초), 기본 8초
# LAW_API_CACHE_TTL=86400        # L1 캐시 유효시간(초), 기본 24시간
# Supabase 설정 시 법조문 캐시가 L2(Supabase)에 7일간 영속 저장됨


# 관리자 페이지 - /admin 접속용 비밀번호
ADMIN_PASSWORD=your_admin_password_here
# ADMIN_JWT_SECRET=별도_JWT_시크릿 (미설정 시 ADMIN_PASSWORD 사용)

# ── 검증 ──────────────────────────────────────────────────────
# python3 check_env.py  — 배포 전 환경변수 검증
